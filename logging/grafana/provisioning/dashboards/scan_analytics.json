{
  "title": "MedicineBox \u2014 Scan Analytics",
  "uid": "medicinebox-scan-analytics",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Loki Source",
        "type": "datasource",
        "pluginId": "loki",
        "refresh": 1,
        "hide": 0,
        "current": {}
      },
      {
        "name": "machine_id",
        "label": "Machine",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": "label_values({job=\"medicine_box\"}, machine_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {}
      },
      {
        "name": "picknote",
        "label": "Picknote",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": "label_values({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\".+\"}, picknote)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "sort": 1,
        "current": {},
        "description": "Filter by picknote. Populated from Loki stream labels (scan_recorded events only)."
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Scans",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])) + sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_rejected\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Total Scans",
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Accepted (incl. corrections)",
      "description": "All successfully accepted scans: normal + batch correction + ambiguous resolved.",
      "type": "stat",
      "gridPos": {
        "x": 3,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Accepted",
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Batch Correction",
      "description": "Subset of accepted: scans where batch was not in picklist but belongs to a picklist product.",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |~ \"kind=correction\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Batch Correction",
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Rejected / Failed",
      "type": "stat",
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_rejected\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Rejected/Failed",
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 41,
      "title": "Total Line Items Done",
      "description": "Product rows fully completed (pending quantity = 0). Responds to the Machine filter above.",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"line_item_completed\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Line Items Done",
          "color": {
            "fixedColor": "teal",
            "mode": "fixed"
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "title": "Accept Rate %",
      "description": "Accepted / (Accepted + Rejected). Complementary to Rejection Rate.",
      "type": "gauge",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])) / (sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])) + sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_rejected\" [$__range]))) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Accept Rate",
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Rejection Rate %",
      "description": "Rejected / (Accepted + Rejected). Complementary to Accept Rate.",
      "type": "gauge",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_rejected\" [$__range])) / (sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])) + sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_rejected\" [$__range]))) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Rejection Rate",
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 15
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Scan Outcomes Over Time",
      "description": "Accepted (Normal) = only picklist batch match. Batch Correction = accepted via alternate batch. Total Accepted = all scan_recorded events.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [5m]))",
          "legendFormat": "Total Accepted \u2014 Machine {{machine_id}}",
          "refId": "E"
        },
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=normal\" [5m]))",
          "legendFormat": "Accepted (Normal) \u2014 Machine {{machine_id}}",
          "refId": "A"
        },
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=correction\" [5m]))",
          "legendFormat": "Batch Correction \u2014 Machine {{machine_id}}",
          "refId": "D"
        },
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"Matching ambiguous\" [5m]))",
          "legendFormat": "Ambiguous \u2014 Machine {{machine_id}}",
          "refId": "B"
        },
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_rejected\" [5m]))",
          "legendFormat": "Rejected \u2014 Machine {{machine_id}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total Accepted"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Accepted (Normal)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-green",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    4,
                    4
                  ],
                  "fill": "dash"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Batch Correction"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Ambiguous"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Rejected"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 8,
      "title": "Rejection Breakdown by Stage",
      "description": "Which pipeline stage is causing most failures",
      "type": "piechart",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"Scan pipeline failed at stage=detection\" [$__range]))",
          "legendFormat": "Detection failed",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"Scan pipeline failed at stage=ocr\" [$__range]))",
          "legendFormat": "OCR failed",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"Scan pipeline failed at stage=matching\" [$__range]))",
          "legendFormat": "Matching failed",
          "refId": "C",
          "instant": true
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Detection failed"
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "OCR failed"
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "C"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Matching failed"
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 9,
      "title": "Accept Rate per Machine",
      "description": "Accept rate % per active machine \u2014 only machines with scan activity in the selected range appear.",
      "type": "bargauge",
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])) / (sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])) + sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_rejected\" [$__range]))) * 100",
          "legendFormat": "Machine {{machine_id}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "values": true,
          "calcs": [],
          "fields": ""
        },
        "displayMode": "lcd",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "OCR Match Miss Rate by Machine",
      "description": "Percentage of total scan attempts where the OCR could not match any batch number. Higher = more unrecognised packages.",
      "type": "bargauge",
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\"} |= \"Batch number not found\" [$__range])) / (sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\"} |= \"scan_recorded\" [$__range])) + sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\"} |= \"scan_rejected\" [$__range]))) * 100",
          "legendFormat": "Machine {{machine_id}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "values": true,
          "calcs": [],
          "fields": ""
        },
        "displayMode": "lcd",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Ambiguous Scans Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"Matching ambiguous\" [5m]))",
          "legendFormat": "Machine {{machine_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Recent Rejected / Failed Scans",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "{job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |~ \"scan_rejected|Scan pipeline failed at stage\"",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 30,
      "title": "Machine Performance",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 25,
      "title": "Ambiguous Scan Rate by Machine",
      "description": "Percentage of total scan attempts that resulted in an ambiguous (multi-match) outcome per machine.",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"ambiguous_resolved\" [$__range])) / (sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])) + sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_rejected\" [$__range]))) * 100",
          "legendFormat": "Machine {{machine_id}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "lcd",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        }
      }
    },
    {
      "id": 27,
      "title": "Hourly Scan Throughput by Machine",
      "description": "Accepted scans per hour \u2014 shows picker productivity and activity windows across the day.",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [1h]))",
          "legendFormat": "Machine {{machine_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
