{
  "title": "MedicineBox \u2014 Pack Box Analytics",
  "uid": "medicinebox-packbox-analytics",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "10s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Loki Source",
        "type": "datasource",
        "pluginId": "loki",
        "refresh": 1,
        "hide": 0,
        "current": {}
      },
      {
        "name": "machine_id",
        "label": "Machine",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": "label_values({job=\"medicine_box\"}, machine_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": {}
      },
      {
        "name": "picknote",
        "label": "Picknote",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": "label_values({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\".+\"}, picknote)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "sort": 1,
        "current": {},
        "description": "Picknote dropdown (multi-select with search). Populated from log stream labels."
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Pack Box Advances",
      "description": "Each click of the Next Pack Box button. Total physical boxes used = advances + number of distinct picknotes (each picknote starts on box 1).",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"packbox_advanced\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Pack Box Advances",
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Batch Corrections",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=correction\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Batch Corrections",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Recorded Scans",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Total Scans",
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Distinct Picknotes",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "count(sum by (picknote) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Picknotes",
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Correction Rate %",
      "description": "Batch correction scans as a share of total scans.",
      "type": "gauge",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=correction\" [$__range])) / sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range])) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "Correction Rate",
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Scan Kind Breakdown (all are Accepted)",
      "description": "All three scan kinds \u2014 Normal, Batch Correction, and Ambiguous Resolved \u2014 count as accepted. The pie shows the split within accepted scans.",
      "type": "piechart",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=normal\" [$__range]))",
          "legendFormat": "Normal",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=correction\" [$__range]))",
          "legendFormat": "Batch correction",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "sum(count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"ambiguous_resolved\" [$__range]))",
          "legendFormat": "Ambiguous resolved",
          "refId": "C",
          "instant": true
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Normal"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Batch correction"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "C"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Ambiguous resolved"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 10,
      "title": "Per-Picknote Summary",
      "description": "One row per picknote \u2014 total accepted (normal + correction + ambiguous), correction count, normal count, and highest pack box used.",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (picknote) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" [$__range]))",
          "format": "table",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum by (picknote) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=normal\" [$__range]))",
          "format": "table",
          "refId": "D",
          "instant": true
        },
        {
          "expr": "sum by (picknote) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=correction\" [$__range]))",
          "format": "table",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "max by (picknote) (max_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" | regexp \"packbox=(?P<packbox>\\\\d+)\" | unwrap packbox [$__range]))",
          "format": "table",
          "refId": "C",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "picknote",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true
            },
            "renameByName": {
              "picknote": "Picknote",
              "Value #A": "Total Accepted",
              "Value #D": "Normal",
              "Value #B": "Corrections",
              "Value #C": "Pack Boxes Used"
            },
            "indexByName": {
              "picknote": 0,
              "Value #A": 1,
              "Value #D": 2,
              "Value #B": 3,
              "Value #C": 4
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [],
            "sort": [
              {
                "field": "Total Accepted",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total Accepted"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Normal"
            },
            "properties": [
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Corrections"
            },
            "properties": [
              {
                "id": "custom.align",
                "value": "right"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pack Boxes Used"
            },
            "properties": [
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 15,
      "title": "Pack Box Advances Over Time by Machine",
      "description": "When pickers switch to a new pack box \u2014 a proxy for box completion rate. Spikes indicate high packing activity.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (machine_id) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"packbox_advanced\" [1h]))",
          "legendFormat": "Machine {{machine_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "fillOpacity": 15
      }
    },
    {
      "id": 12,
      "title": "Top Products by Total Scans",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 9
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "topk(20, sum by (product) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" | regexp \"product='(?P<product>[^']+)'\" [$__range])))",
          "format": "table",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "product": "Product",
              "Value": "Scans"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [],
            "sort": [
              {
                "field": "Scans",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "id": 13,
      "title": "Top Products by Batch Corrections",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 30,
        "w": 12,
        "h": 9
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "topk(20, sum by (product) (count_over_time({job=\"medicine_box\", machine_id=~\"$machine_id\", picknote=~\"$picknote\"} |= \"scan_recorded\" |= \"kind=correction\" | regexp \"product='(?P<product>[^']+)'\" [$__range])))",
          "format": "table",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "product": "Product",
              "Value": "Corrections"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [],
            "sort": [
              {
                "field": "Corrections",
                "desc": true
              }
            ]
          }
        }
      ]
    }
  ]
}
